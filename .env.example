# ─── Supabase ─────────────────────────────────────────────
# Required for /api/contact, /api/newsletter, /api/orders to persist data.
# Get these at https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Site ─────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Safepay (debit / credit card payments) ───────────────
# Get test keys from https://getsafepay.com → Dashboard → Developers
# Use "sandbox" while testing, switch to "production" when live.
SAFEPAY_ENV=sandbox
SAFEPAY_SECRET_KEY=your-safepay-secret-key
NEXT_PUBLIC_SAFEPAY_PUBLIC_KEY=your-safepay-public-key

# ─── Admin dashboard ──────────────────────────────────────
# Credentials Komal will enter at /admin/login. Defaults are baked into the
# code so the admin works without these, but set them in production.
ADMIN_EMAIL=webdev.muhammad@gmail.com
ADMIN_PASSWORD=Komals@1
# A long random string used to sign the admin session cookie.
# Generate with: openssl rand -base64 48
ADMIN_SESSION_SECRET=please-change-this-to-a-long-random-string
